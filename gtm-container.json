        "type": "html",
        "parameter": [
          {"type": "TEMPLATE", "key": "html", "value": "<script>\n(function(){\n  if (window.__gcAdsenseTracker) return;\n  window.__gcAdsenseTracker = true;\n  var dl = window.dataLayer = window.dataLayer || [];\n  var seen = new WeakSet();\n  var lastFocusedAd = null;\n\n  function push(eventName, el) {\n    dl.push({\n      event: eventName,\n      ad_slot: el.getAttribute('data-ad-slot') || '',\n      ad_format: el.getAttribute('data-ad-format') || 'auto',\n      ad_client: el.getAttribute('data-ad-client') || ''\n    });\n  }\n\n  function scanImpressions() {\n    var ads = document.querySelectorAll('ins.adsbygoogle');\n    if (!ads.length || !('IntersectionObserver' in window)) return;\n    var io = new IntersectionObserver(function(entries){\n      entries.forEach(function(e){\n        if (e.isIntersecting && e.intersectionRatio >= 0.5 && !seen.has(e.target)) {\n          seen.add(e.target);\n          push('ad_impression', e.target);\n        }\n      });\n    }, { threshold: 0.5 });\n    ads.forEach(function(el){ if (!seen.has(el)) io.observe(el); });\n  }\n\n  function setupClickTracking() {\n    document.addEventListener('mousedown', function(ev){\n      var el = ev.target && ev.target.closest && ev.target.closest('ins.adsbygoogle');\n      lastFocusedAd = el || null;\n    }, true);\n    window.addEventListener('blur', function(){\n      setTimeout(function(){\n        if (document.activeElement && document.activeElement.tagName === 'IFRAME' && lastFocusedAd) {\n          push('ad_click', lastFocusedAd);\n          lastFocusedAd = null;\n        }\n      }, 0);\n    });\n  }\n\n  if (document.readyState === 'loading') {\n    document.addEventListener('DOMContentLoaded', function(){ scanImpressions(); setupClickTracking(); });\n  } else {\n    scanImpressions();\n    setupClickTracking();\n  }\n  setInterval(scanImpressions, 3000);\n})();\n<\/script>"},
